{
  "name": "quantuml7ai-fullstarter",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "pnpm -s clean && next dev",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "lint": "eslint . --ext .js,.jsx,.mjs,.cjs --max-warnings=0",
    "typecheck": "tsc --noEmit --pretty false",
    "verify:env": "node tools/verify-environment.mjs",
    "verify:docs": "node tools/verify-docs-workflow.mjs",
    "verify:audits": "node tools/run-verification-audits.mjs --mode fast",
    "verify:audits:fast": "node tools/run-verification-audits.mjs --mode fast",
    "verify:audits:deep": "node tools/run-verification-audits.mjs --mode deep",
    "verify:forum:runtime": "node tools/run-governance-group.mjs forum-runtime",
    "verify:auth:fanout": "node tools/run-governance-group.mjs auth-fanout",
    "verify:startup:budgets": "node tools/run-governance-group.mjs startup-budgets",
    "verify:route:budgets": "node tools/run-governance-group.mjs route-budgets",
    "verify:media:har": "node tools/run-governance-group.mjs media-har",
    "verify:media:heap": "node tools/run-governance-group.mjs media-heap",
    "verify:mobile:matrix": "node tools/run-governance-group.mjs mobile-matrix",
    "verify:ads:runtime": "node tools/run-governance-group.mjs ads-runtime",
    "verify:exchange:widgets": "node tools/run-governance-group.mjs exchange-widgets",
    "verify:scenario:forum-mobile": "node tools/run-scenario-telemetry.mjs forum-mobile",
    "verify:scenario:forum-desktop": "node tools/run-scenario-telemetry.mjs forum-desktop",
    "verify:scenario:forum-route-return": "node tools/run-scenario-telemetry.mjs forum-route-return",
    "verify:scenario:auth-cascade": "node tools/run-scenario-telemetry.mjs auth-cascade",
    "verify:scenario:startup-shell": "node tools/run-scenario-telemetry.mjs startup-shell",
    "verify:scenario:exchange-route": "node tools/run-scenario-telemetry.mjs exchange-route",
    "verify:scenario:decorative-media": "node tools/run-scenario-telemetry.mjs decorative-media",
    "verify:scenario:forum-long-scroll": "node tools/run-scenario-telemetry.mjs forum-long-scroll",
    "verify:scenario:forum-background-restore": "node tools/run-scenario-telemetry.mjs forum-background-restore",
    "verify:scenario:forum-wallet-untouched": "node tools/run-scenario-telemetry.mjs forum-wallet-untouched",
    "verify:scenario:qcast-mixed": "node tools/run-scenario-telemetry.mjs qcast-mixed",
    "verify:scenario:provider-baseline": "node tools/run-scenario-telemetry.mjs provider-baseline",
    "verify:scenario:route-teardown": "node tools/run-scenario-telemetry.mjs route-teardown",
    "verify:scenario:preload-waste": "node tools/run-scenario-telemetry.mjs preload-waste",
    "verify:scenario:console-noise": "node tools/run-scenario-telemetry.mjs console-noise",
    "verify:scenario:adaptive-pressure": "node tools/run-scenario-telemetry.mjs adaptive-pressure",
    "verify:scenario:forensic-mode": "node tools/run-scenario-telemetry.mjs forensic-mode",
    "verify:diff:last-baseline": "node tools/compare-baselines.js --stage stage0",
    "test:contracts": "vitest run --configLoader native --project contracts",
    "test:unit": "vitest run --configLoader native --project unit",
    "test:component": "vitest run --configLoader native --project component",
    "test:integration": "vitest run --configLoader native --project integration",
    "test:smoke": "vitest run --configLoader native --project smoke",
    "test:coverage": "vitest run --configLoader native --coverage",
    "test:quick": "node tools/test-codex.mjs --quick",
    "test:codex": "node tools/test-codex.mjs",
    "verify": "pnpm test:codex",
    "build": "next build",
    "start": "next start",
    "project:docs": "node tools/generate-project-docs.js",
    "project:docs:audit": "node tools/audit-project-docs.js",
    "project:docs:full": "pnpm project:docs && pnpm project:docs:audit",
    "audit:forum:diag": "node tools/analyze-forum-diag.js",
    "audit:forum:har": "node tools/analyze-forum-media-har.js"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.15.13",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.51.21",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tensorflow/tfjs-layers": "^4.22.0",
    "@tonconnect/ui": "^2.3.0",
    "@tonconnect/ui-react": "^2.3.0",
    "@upstash/redis": "^1.35.4",
    "@vercel/analytics": "^1.5.0",
    "@vercel/blob": "^2.0.0",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^1.2.0",
    "@web3modal/wagmi": "^5.1.11",
    "deepl-node": "^1.22.0",
    "dotenv": "^17.2.3",
    "jpeg-js": "^0.4.4",
    "next": "14.2.5",
    "nodemailer": "^7.0.10",
    "nsfwjs": "^4.2.1",
    "pngjs": "^7.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-virtuoso": "^4.18.1",
    "sharp": "^0.34.4",
    "three": "^0.163.0",
    "undici": "^7.16.0",
    "viem": "^2.16.5",
    "wagmi": "^2.12.10"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.5",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  }
}
