# QL7 local environment example
# Copy this file to .env.local and fill secrets locally.

# ===== Stage 0 runtime mode contract =====
# Local defaults: deep awareness enabled, adaptive core shadowed, forensics off unless enabled explicitly.
NEXT_PUBLIC_ROUTE_BUDGET_DEBUG=1
NEXT_PUBLIC_CONSOLE_NOISE_CLASSIFIER=1

# ===== Site secrets =====
SITE_LINK_SECRET=change-me

# ===== Canonical public site URL =====
# Used by canonical metadata, robots.txt, sitemap.xml and structured data.

# ===== Bot API (to write subs.json on your server) =====
BOT_API_URL=https://api.quantuml7ai.com/api/subs/grant
BOT_API_KEY=change-me

# ===== NOWPayments (optional, for real payments) =====
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PRICE_PRO=10
NOWPAYMENTS_PRICE_VIP=19.99
NOWPAYMENTS_CURRENCY=USD
NOWPAYMENTS_CALLBACK=https://quantuml7ai.com/api/payments/now/webhook
NOWPAYMENTS_SUCCESS_URL=https://quantuml7ai.com/subscribe?status=success
NOWPAYMENTS_CANCEL_URL=https://quantuml7ai.com/subscribe?status=cancel
# === Базовые урлы ===
APP_URL=https://<your-domain>
NEXT_PUBLIC_META_VERSION=20260212

# === Redis (Upstash) ===
UPSTASH_REDIS_REST_URL=https://<your-upstash-url>
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# === Web Push / Android TWA background notifications ===
# Generate once with: node -e "console.log(require('web-push').generateVAPIDKeys())"
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@quantuml7ai.com

# === Native Android-app-only FCM (server-only Firebase service account fields) ===
# Ordinary browsers continue using the WEB_PUSH_VAPID_* contour above.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Keep escaped newlines in Vercel/local env: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FCM_PRIVATE_KEY=

# === Админ-доступ (прод) ===
FORUM_ADMIN_PASS=<strong-64+chars-random>
FORUM_REQUIRE_ADMIN_PASS=true
# Не публикуем админ-пароль на клиент (НЕ задавай NEXT_PUBLIC_FORUM_ADMIN_PASS в проде)

# --- React (эмоции) ---
# Глобальный форум: баланс между UX и анти-спамом
FORUM_REACTS_PER_MINUTE=60        # до 60 реакций/мин с одного актора
FORUM_MIN_INTERVAL_SEC=2          # минимум 2 сек между реакциями

# --- Reports (жалобы/баны) ---
# Для «всей планеты»: сниженный порог и более длинный бан
FORUM_REPORT_THRESHOLD=7          # 7 уникальных жалоб -> бан
FORUM_BAN_SECONDS=259200          # 3 суток (в секундах)

# --- Views (просмотры) ---
# 30 минут ок, можно чуть мягче для CDN/мобильных сетей
FORUM_VIEW_TTL_SEC=1800           # антинакрутка просмотров, 30 минут
FORUM_VIEW_TIMEOUT_MS=6000        # таймаут на операции с просмотрами (REST Upstash)

# --- Общие таймауты Redis ---
FORUM_REDIS_TIMEOUT_MS=6000       # общий таймаут на Redis-операции

# === Безопасность API (рекомендуется на уровне кода/платформы) ===
# Эти флаги не обязательны, но напоминание:
# NODE_ENV=production        # проставится автоматически на Vercel
# === Forum diagnostics master switch ===
# Production-safe defaults.
NEXT_PUBLIC_FORUM_EARLY_DIAG_ENABLED=0
NEXT_PUBLIC_FORUM_DIAG=0
NEXT_PUBLIC_FORUM_PERF_TRACE=0

# Canonical public origin required by verification gates.
NEXT_PUBLIC_SITE_URL=https://www.quantuml7ai.com

# Runtime mode contract defaults for local/stage/prod verification.
# Production secrets still belong in .env.local or provider env, not in this example file.
APP_RUNTIME_MODE=production-adaptive
APP_DIAGNOSTICS_MODE=off
APP_FORENSIC_MODE=off
APP_TELEMETRY_LEVEL=T0
APP_ADAPTIVE_CORE_MODE=enforced
NEXT_PUBLIC_RUNTIME_MODE=production-adaptive
NEXT_PUBLIC_DIAGNOSTICS_MODE=off
NEXT_PUBLIC_ADAPTIVE_CORE=enforced
NEXT_PUBLIC_FORENSIC_ALLOWED=false
